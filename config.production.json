{
  "version": "2.1.0",
  "description": "Production configuration - optimized for high availability and security",
  "server": {
    "host": "0.0.0.0",
    "port": 9999,
    "data_dir": "/var/lib/kosdb/data",
    "max_connections": 1000,
    "connection_timeout": 30,
    "request_timeout": 300
  },
  "tls": {
    "enabled": true,
    "cert_file": "/etc/kosdb/certs/server.crt",
    "key_file": "/etc/kosdb/certs/server.key",
    "ca_file": "/etc/kosdb/certs/ca.crt",
    "require_client_cert": false,
    "ssl_version": "TLS"
  },
  "cache": {
    "enabled": true,
    "max_size": 10000,
    "default_ttl": 600,
    "invalidate_on_write": true
  },
  "gpu": {
    "enabled": false,
    "device_id": 0,
    "memory_limit_mb": null,
    "batch_size": 1000,
    "use_mixed_precision": false
  },
  "fulltext": {
    "enabled": true,
    "stem": true,
    "min_token_length": 2,
    "custom_stop_words": []
  },
  "vector_search": {
    "enabled": true,
    "default_dimension": 384,
    "metric": "cosine",
    "use_gpu": false
  },
  "replication": {
    "enabled": true,
    "role": "master",
    "slaves": [
      {"host": "slave1.example.com", "port": 9999},
      {"host": "slave2.example.com", "port": 9999}
    ],
    "replication_port": 9998
  },
  "failover": {
    "enabled": true,
    "node_id": "prod_node1",
    "peers": [
      {"id": "prod_node2", "host": "192.168.1.2", "port": 9000},
      {"id": "prod_node3", "host": "192.168.1.3", "port": 9000}
    ],
    "raft_port": 9000
  },
  "monitoring": {
    "enabled": true,
    "http_port": 9090,
    "metrics_path": "/metrics",
    "health_path": "/health"
  },
  "logging": {
    "level": "WARNING",
    "file": "/var/log/kosdb/server.log",
    "max_size_mb": 500,
    "backup_count": 10
  }
}
