command = "VECTOR SEARCH BATCH my_index [('q1', [0.1, 0.2, 0.3]), ('q2', [0.4, 0.5, 0.6])] LIMIT 5"

# Better approach: find the outer brackets by counting
def extract_bracket_content(s, start_char='[', end_char=']'):
    """Extract content from balanced brackets."""
    start = s.find(start_char)
    if start == -1:
        return None
    
    count = 0
    for i in range(start, len(s)):
        if s[i] == start_char:
            count += 1
        elif s[i] == end_char:
            count -= 1
            if count == 0:
                return s[start+1:i]
    return None

index_match = re.search(r'VECTOR\s+SEARCH\s+BATCH\s+(\w+)', command, re.IGNORECASE)
if index_match:
    index_name = index_match.group(1)
    rest = command[index_match.end():]
    
    content = extract_bracket_content(rest)
    print(f"Content: {repr(content)}")
    
    # Parse limit
    after_bracket = rest[rest.find(']')+1:]
    limit_match = re.search(r'LIMIT\s+(\d+)', after_bracket, re.IGNORECASE)
    k = int(limit_match.group(1)) if limit_match else 10
    
    print(f"K: {k}")
    
    # Parse queries
    if content:
        query_pattern = r"\(\s*'([^']+)'\s*,\s*\[([^\]]+)\]\s*\)"
        queries = []
        for m in re.finditer(query_pattern, content):
            print(f"  Found: {m.group(1)}")
            queries.append(m.group(1))
        
        print(f"Total: {len(queries)}") | SUCCESS: True | OUTPUT_LEN: 98
