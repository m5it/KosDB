with open('database.py') as f:
    content = f.read()

# Check for duplicate method definitions
methods = re.findall(r'^\s+def (\w+)\(', content, re.MULTILINE)
duplicates = [m for m in set(methods) if methods.count(m) > 1]
if duplicates:
    print(f"WARNING: Duplicate methods: {duplicates}")
else:
    print("OK: No duplicate methods")

# Check class structure
if content.count('class Database:') != 1:
    print(f"WARNING: Found {content.count('class Database:')} 'class Database:' definitions")
else:
    print("OK: Single class Database definition")

# Check for proper imports at top
if 'import threading' not in content:
    print("WARNING: Missing 'import threading'")
else:
    print("OK: threading imported")

if 'import glob' not in content:
    print("WARNING: Missing 'import glob'")
else:
    print("OK: glob imported")

print("All checks passed!") | SUCCESS: True | OUTPUT_LEN: 122
